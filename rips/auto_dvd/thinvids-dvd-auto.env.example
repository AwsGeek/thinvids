# Copy to /etc/default/thinvids-dvd-auto and adjust for your host.

# Absolute path to dvd_rip_queue.py
THINVIDS_DVD_RIP_SCRIPT=/home/jerry/apps/thinvids/rips/dvd_rip_queue.py

# Python interpreter to run the rip script
THINVIDS_DVD_PYTHON=python3

# thinvids input settings
THINVIDS_DVD_WATCH_ROOT=/home/jerry/media/data/media
THINVIDS_DVD_OUTPUT_SUBDIR=movies/dvdrips
THINVIDS_DVD_QUEUE_MODE=watch
# THINVIDS_DVD_MANAGER_URL=http://localhost:5005/add_job

# Scratch space used by dvd_rip_queue.py
THINVIDS_DVD_SCRATCH_ROOT=/home/jerry/thinvids-dvd-tmp

# TMDb is optional but strongly recommended for accurate auto-title matching
THINVIDS_DVD_TMDB_API_KEY=

# Auto-title heuristics
THINVIDS_DVD_MIN_SECONDS=2400
THINVIDS_DVD_AUTO_TITLE_MIN_SCORE=60
THINVIDS_DVD_START_DELAY_SEC=8

# Logging / locking
THINVIDS_DVD_LOCK_DIR=/run/lock
THINVIDS_DVD_DEBUG=0
